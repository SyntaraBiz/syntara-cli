{
  "name": "syntara",
  "version": "1.0.0",
  "description": "Herramienta interna de CLI para proyectos SyntaraBiz",
  "main": "bin/syntara.js",
  "type": "module",
  "exports": {
    ".": "./bin/syntara.js",
    "./astro": "./dist/integrations/astro/index.js",
    "./vite": "./dist/integrations/vite/index.js",
    "./core/*": "./dist/core/*.js"
  },
  "bin": {
    "syntara": "./bin/syntara.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "syntara",
    "cli"
  ],
  "author": "SyntaraBiz",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
